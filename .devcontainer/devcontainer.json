{
  "name": "gbemu",
  "image": "mcr.microsoft.com/devcontainers/go:1.21",
  "features": {
    "ghcr.io/devcontainers/features/desktop-lite:1": {
      "version": "latest",
      "vncType": "kasmvnc",
      "password": "vscode",
      "webPort": "6080",
      "vncPort": "5901"
    }
  },
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "🎮 Game Boy Desktop (KasmVNC)",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "cd /workspaces/gbemu && go mod tidy",
  "customizations": {
    "vscode": {
      "extensions": ["golang.go"],
      "settings": {
        "go.toolsManagement.autoUpdate": true
      }
    }
  },
  "remoteEnv": {
    "DISPLAY": ":1"
  }
}
